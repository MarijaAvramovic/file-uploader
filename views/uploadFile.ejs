<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home</title>
  <link rel="stylesheet" href="/css/home.css">
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">File Uploader App</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <% if (currentUser) { %>

         
        <a href="/auth/log-out">Logout</a>
         
      <% } else { %>
        <a href="/auth/signup">Sing up</a>
      <% } %>
    </div>
  </nav>

  <!-- MAIN CONTAINER -->
  <div class="container">

 

    <% if (currentUser) { %>

      

     <div class="card description">

  <h2 class="upload-title">Upload a file</h2>

  <form 
    action="/action/upload-file" 
    method="POST" 
    enctype="multipart/form-data"
    class="upload-form"
  >

    <!-- FILE INPUT -->
    <div class="form-group">
      <label for="file">Choose File</label>

      <div class="file-upload-wrapper">
        <input 
          type="file" 
          id="file" 
          name="file"
          required
        >
      </div>
    </div>

    <!-- FOLDER SELECT -->
    <div class="form-group">
      <label for="folder">Select Folder (Optional)</label>

      <select id="folder" name="folder">
        <option value="">No Folder</option>
<% (folders || []).forEach(folder => { %>
  <option value="<%= folder.id %>">
    <%= folder.name %>
  </option>
<% }) %>

      </select>
    </div>

    <!-- SUBMIT -->
    <button type="submit" class="upload-btn">
      Upload File
    </button>

  </form>

</div>

    <% } else { %>

      <h2 class="welcome">Please log in</h2>

      <form action="/auth/log-in" method="POST">

        <div class="form-group">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" placeholder="Enter username" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Enter password" />
        </div>

        <button type="submit">Log In</button>
      </form>

    <% } %>

  </div>

</body>
</html>