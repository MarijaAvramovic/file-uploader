<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home</title>
  <link rel="stylesheet" href="/css/home.css">
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">File Uploader App</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <% if (currentUser) { %>

         <a href="/auth/log-out">Dashboard</a>
        <a href="/auth/log-out">Logout</a>
         
      <% } else { %>
        <a href="/auth/signup">Sing up</a>
      <% } %>
    </div>
  </nav>

  <!-- MAIN CONTAINER -->
  <div class="container">

    <h1>Upload files</h1>

    <% if (currentUser) { %>

      

     <div class="card description">

  <h2 class="upload-title">Folders</h2>

 <ul>
  <% folders.forEach(folder => { %>

    <li>
      <a href="/folders/<%= folder.id %>">
        <%= folder.name %>
      </a>

      <a href="/folders/<%= folder.id %>/edit">
        Edit
      </a>

      <form
        action="/folders/<%= folder.id %>/delete"
        method="POST"
        style="display:inline;"
      >
        <button type="submit">
          Delete
        </button>
      </form>
    </li>

  <% }) %>
</ul>

</div>

    <% } else { %>

      <h2 class="welcome">Please log in</h2>

      <form action="/auth/log-in" method="POST">

        <div class="form-group">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" placeholder="Enter username" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Enter password" />
        </div>

        <button type="submit">Log In</button>
      </form>

    <% } %>

  </div>

</body>
</html>