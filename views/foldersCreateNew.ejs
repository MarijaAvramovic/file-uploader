<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home</title>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">File Uploader App</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <% if (currentUser) { %>

       
           <a href="/action/view-folders">🔒 Folders</a>  
        <a href="/auth/log-out">Logout</a>
         
      <% } else { %>
        <a href="/auth/signup">Sing up</a>
      <% } %>
    </div>
  </nav>

  <!-- MAIN CONTAINER -->
  <div class="container">

    
<h2 class="upload-title">Create New Folder</h2>
    <% if (currentUser) { %>

       <div class="card description">

    <form action="/action/view-folders/create" method="POST" class="folder-form">

      <div class="input-wrapper">
        <i class="fa-solid fa-folder-plus"></i>
        <input 
          type="text" 
          name="name" 
          placeholder="Enter folder name..." 
          required 
        />
      </div>

      <button type="submit" class="submit-btn">
        Create Folder
      </button>

    </form>

  </div>

      

    <% } else { %>

      <h2 class="welcome">Please log in</h2>

      <form action="/auth/log-in" method="POST">

        <div class="form-group">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" placeholder="Enter username" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Enter password" />
        </div>

        <button type="submit">Log In</button>
      </form>

    <% } %>

  </div>

</body>
</html>