<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home</title>
  <link rel="stylesheet" href="/css/home.css">
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">File Uploader App</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <% if (currentUser) { %>

         <a href="/auth/log-out">Dashboard</a>
        <a href="/auth/log-out">Logout</a>
         
      <% } else { %>
        <a href="/auth/signup">Sing up</a>
      <% } %>
    </div>
  </nav>

  <!-- MAIN CONTAINER -->
  <div class="container">

    <h1>Organize your files</h1>

    <% if (currentUser) { %>

      <h2 class="welcome">
        WELCOME <%= currentUser.username %>
      </h2>

     <div class="card description">
   
      
<h4>list of folders</h4>
      <ul>
        <li>⚡ Fast file uploads</li>
        <li>🔒 Secure authentication</li>
        <li>☁️ Cloud-ready storage</li>
        <li>📱 Mobile friendly</li>
      </ul>
    </div>

    <% } else { %>

      <h2 class="welcome">Please log in</h2>

      <form action="/auth/log-in" method="POST">

        <div class="form-group">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" placeholder="Enter username" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Enter password" />
        </div>

        <button type="submit">Log In</button>
      </form>

    <% } %>

  </div>

</body>
</html>