<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home</title>
  <link rel="stylesheet" href="/css/home.css">
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">File Uploader App</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <% if (currentUser) { %>

          
        <a href="/auth/log-out">Logout</a>
         
      <% } else { %>
        <a href="/auth/signup">Sing up</a>
      <% } %>
    </div>
  </nav>

  <!-- MAIN CONTAINER -->
  <div class="container">

    

    <% if (currentUser) { %>

      <h2 class="welcome">
        WELCOME <%= currentUser.name.toUpperCase(); %>
      </h2>

     <div class="card description">
   
 <h3>Organize your files</h3>
      <ul>
       <a href="/action/upload-file"><li>⚡ Upload files</li></a>  
       <a href="/action/view-folders"><li>🔒 Folders</li></a>  
         <a href="/action/view-files"><li>☁️ Files</li></a>  
       
      </ul>
    </div>

    <% } else { %>

      <h2 class="welcome">Please log in</h2>

      <form action="/auth/log-in" method="POST">

        <div class="form-group">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" placeholder="Enter username" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Enter password" />
        </div>

        <button type="submit">Log In</button>
      </form>

    <% } %>

  </div>

</body>
</html>